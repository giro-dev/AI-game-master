<div class="ai-gm-panel">
  {{!-- Primary Tab Navigation --}}
  <nav class="ai-gm-tabs" data-group="primary">
    <a class="item" data-tab="generator"><i class="fas fa-magic"></i> Generator</a>
    <a class="item" data-tab="chat"><i class="fas fa-comments"></i> Chat</a>
    <a class="item" data-tab="configuration"><i class="fas fa-cogs"></i> Configuration</a>
    <a class="item" data-tab="game-director"><i class="fas fa-dragon"></i> Game Director</a>
    <a class="item" data-tab="transcription"><i class="fas fa-microphone"></i> Transcription</a>
  </nav>

  <section class="ai-gm-tab-content">

    {{!-- ═══ GENERATOR TAB ═══ --}}
    <div class="tab" data-tab="generator" data-group="primary">
      <nav class="ai-gm-subtabs">
        <a class="item active" data-subtab="generate-characters"><i class="fas fa-users"></i> Characters</a>
        <a class="item" data-subtab="generate-items"><i class="fas fa-hat-wizard"></i> Items</a>
      </nav>

      {{!-- Characters subtab --}}
      <div class="ai-gm-subtab-content active" data-subtab-content="generate-characters">
        <div class="form-group">
          <label for="gm-actor-type">Character Type</label>
          <select id="gm-actor-type">
            {{#each actorTypes}}
            <option value="{{this.id}}" {{#if this.selected}}selected{{/if}}>{{this.label}}</option>
            {{/each}}
          </select>
        </div>

        <div class="form-group field-selector">
          <div class="field-selector-header">
            <label>Fields for Generation</label>
            <div>
              <button type="button" class="btn btn-sm" data-action="select-all-fields">All</button>
              <button type="button" class="btn btn-sm" data-action="deselect-all-fields">None</button>
            </div>
          </div>
          <div class="field-tree" id="gm-field-tree">
            {{{fieldTreeHTML}}}
          </div>
          <p class="hint">Selected fields will be generated by AI. Others use defaults.</p>
        </div>

        {{#if referenceCharacter}}
        <div class="reference-indicator">
          <i class="fas fa-user-check"></i>
          Reference: <strong>{{referenceCharacter.label}}</strong>
          <span class="hint">({{referenceCharacter.itemCount}} items)</span>
        </div>
        {{/if}}

        <div class="form-group">
          <label for="gm-char-lang">Language</label>
          <select id="gm-char-lang">
            <option value="en">English</option>
            <option value="es">Español</option>
            <option value="ca" selected>Català</option>
            <option value="fr">Français</option>
            <option value="de">Deutsch</option>
          </select>
        </div>

        <div class="form-group">
          <label for="gm-char-prompt">Character Description</label>
          <textarea id="gm-char-prompt" rows="3" placeholder="Describe the character you want to create..."></textarea>
          <p class="hint">Example: "A brave elven ranger who protects the forest"</p>
        </div>

        <div class="btn-row">
          <button type="button" class="btn btn-primary btn-block" data-action="generate-character">
            <i class="fas fa-magic"></i> Generate Character
          </button>
          <button type="button" class="btn" data-action="view-blueprint">
            <i class="fas fa-file-code"></i> Blueprint
          </button>
        </div>

        <div class="progress-container" id="char-progress">
          <div class="progress-status">
            <i class="fas fa-spinner fa-spin"></i>
            <span id="char-progress-text">Generating...</span>
          </div>
          <div class="progress-bar-track">
            <div class="progress-bar-fill" id="char-progress-bar"></div>
          </div>
        </div>

        <div id="char-result"></div>
      </div>

      {{!-- Items subtab --}}
      <div class="ai-gm-subtab-content" data-subtab-content="generate-items">
        <div class="form-group">
          <label for="gm-item-prompt">Item Description</label>
          <textarea id="gm-item-prompt" rows="3" placeholder="Describe the items to generate..."></textarea>
          <p class="hint">Example: "A legendary fire sword and a healing potion"</p>
        </div>

        <div class="form-group">
          <label for="gm-item-pack">Target Compendium</label>
          <select id="gm-item-pack">
            {{#each itemPacks}}
            <option value="{{this.id}}">{{this.label}}</option>
            {{/each}}
            {{#unless itemPacks.length}}
            <option value="" disabled>No Item compendiums available</option>
            {{/unless}}
          </select>
        </div>

        <div class="btn-row">
          <button type="button" class="btn btn-primary btn-block" data-action="generate-items">
            <i class="fas fa-hat-wizard"></i> Generate Items
          </button>
        </div>

        <div class="progress-container" id="item-progress">
          <div class="progress-status">
            <i class="fas fa-spinner fa-spin"></i>
            <span id="item-progress-text">Generating...</span>
          </div>
          <div class="progress-bar-track">
            <div class="progress-bar-fill" id="item-progress-bar"></div>
          </div>
        </div>
      </div>
    </div>

    {{!-- ═══ CHAT TAB ═══ --}}
    <div class="tab" data-tab="chat" data-group="primary">
      <p class="hint">Ask the AI Game Master anything — rules questions, narration help, action resolution.</p>

      <div class="selected-tokens-widget">
        <div class="selected-tokens-header">
          <label>
            <input type="checkbox" id="gm-include-tokens" checked>
            <i class="fas fa-users"></i> Include tokens
          </label>
        </div>

        <div class="token-section">
          <div class="token-section-title"><i class="fas fa-mouse-pointer"></i> Canvas selection</div>
          <div class="selected-tokens-list" id="gm-selected-tokens">
            <span class="empty-state">No tokens selected on canvas</span>
          </div>
        </div>

        <div class="token-section">
          <div class="token-section-title"><i class="fas fa-list"></i> Scene tokens</div>
          <div class="scene-tokens-actions">
            <button type="button" class="btn" data-action="sync-tokens" title="Copy the current canvas selection into the list below">
              <i class="fas fa-sync"></i> Use canvas selection
            </button>
            <button type="button" class="btn" data-action="clear-tokens" title="Clear selected tokens">
              <i class="fas fa-times"></i> Clear
            </button>
          </div>
          <div class="scene-tokens-list" id="gm-scene-tokens">
            <span class="empty-state">No scene loaded</span>
          </div>
          <p class="hint">Selection here is kept even if the canvas selection is cleared (e.g. when switching tools).</p>
        </div>
      </div>

      <div class="chat-log" id="gm-chat-log">
        {{#each chatHistory}}
        <div class="chat-entry">
          <span class="chat-sender">{{this.sender}}</span>
          <div class="chat-text">{{{this.text}}}</div>
        </div>
        {{/each}}
        {{#unless chatHistory.length}}
        <p class="empty-state">No messages yet. Ask the AI something!</p>
        {{/unless}}
      </div>

      <div class="form-group">
        <textarea id="gm-session-prompt" rows="2" placeholder="Ask the AI Game Master..."></textarea>
      </div>

      <div class="btn-row">
        <button type="button" class="btn btn-primary btn-block" data-action="ask-ai">
          <i class="fas fa-paper-plane"></i> Ask AI
        </button>
      </div>
    </div>

    {{!-- ═══ CONFIGURATION TAB ═══ --}}
    <div class="tab" data-tab="configuration" data-group="primary">
      <nav class="ai-gm-subtabs">
        <a class="item active" data-subtab="config-library"><i class="fas fa-book"></i> Library</a>
        <a class="item" data-subtab="config-configuration"><i class="fas fa-cogs"></i> Configuration</a>
        <a class="item" data-subtab="config-features"><i class="fas fa-sliders-h"></i> Features</a>
      </nav>

      {{!-- Library subtab --}}
      <div class="ai-gm-subtab-content active" data-subtab-content="config-library">
        <h4 class="section-header">Upload a Book</h4>
        <div class="form-group">
          <label for="gm-book-title">Book Title</label>
          <input type="text" id="gm-book-title" placeholder="e.g. Player's Handbook" />
        </div>
        <div class="form-group">
          <label for="gm-book-file">PDF File</label>
          <input type="file" id="gm-book-file" accept=".pdf" />
        </div>
        <div class="btn-row">
          <button type="button" class="btn btn-primary btn-block" data-action="upload-book">
            <i class="fas fa-upload"></i> Upload &amp; Ingest
          </button>
        </div>

        <h4 class="section-header">Ingest a Compendium</h4>
        <div class="form-group">
          <label for="gm-knowledge-pack">Compendium</label>
          <select id="gm-knowledge-pack">
            {{#each knowledgePacks}}
            <option value="{{this.id}}">{{this.label}} ({{this.documentName}})</option>
            {{/each}}
            {{#unless knowledgePacks.length}}
            <option value="" disabled>No compendiums available</option>
            {{/unless}}
          </select>
          <p class="hint">Index a Foundry compendium as RAG knowledge for this world.</p>
        </div>
        <div class="btn-row">
          <button type="button" class="btn btn-primary btn-block" data-action="ingest-compendium">
            <i class="fas fa-database"></i> Ingest Compendium
          </button>
        </div>

        <div class="progress-container" id="ingest-progress">
          <div class="progress-status">
            <i class="fas fa-spinner fa-spin"></i>
            <span id="ingest-progress-text">Processing…</span>
          </div>
          <div class="progress-bar-track">
            <div class="progress-bar-fill" id="ingest-progress-bar"></div>
          </div>
        </div>

        <h4 class="section-header">Books in this World</h4>
        <div class="book-list" id="gm-book-list">
          {{#each books}}
          <div class="book-entry" data-book-id="{{this.bookId}}">
            <div>
              <strong>{{this.displayTitle}}</strong>
              <span class="book-meta">{{this.sourceLabel}}</span>
              <span class="book-meta">{{this.status}}</span>
              {{#if this.chunkCount}}
              <span class="book-meta">({{this.chunkCount}} chunks, {{this.entityCount}} entities)</span>
              {{/if}}
            </div>
            <button type="button" class="btn-danger" data-action="delete-book" data-book-id="{{this.bookId}}" title="Remove book">
              <i class="fas fa-trash"></i>
            </button>
          </div>
          {{/each}}
          {{#unless books.length}}
          <p class="empty-state">No books uploaded yet.</p>
          {{/unless}}
        </div>
      </div>

      {{!-- Configuration subtab --}}
      <div class="ai-gm-subtab-content" data-subtab-content="config-configuration">
        <h4 class="section-header">System Information</h4>
        <div class="profile-grid">
          <div class="profile-card">
            <h5>Game System</h5>
            <div class="value">{{systemTitle}} ({{systemId}})</div>
          </div>
          <div class="profile-card">
            <h5>Foundry Version</h5>
            <div class="value">{{foundryVersion}}</div>
          </div>
          <div class="profile-card">
            <h5>Actor Types</h5>
            <ul>
              {{#each actorTypeNames}}
              <li>{{this}}</li>
              {{/each}}
            </ul>
          </div>
          <div class="profile-card">
            <h5>Item Types</h5>
            <ul>
              {{#each itemTypeNames}}
              <li>{{this}}</li>
              {{/each}}
            </ul>
          </div>
        </div>

        <h4 class="section-header">AI Knowledge Profile</h4>
        {{#if profile}}
        <div class="profile-grid">
          <div class="profile-card">
            <h5>Status</h5>
            <span class="status-badge learned">Learned</span>
            {{#if profile.enrichedFromManuals}}
            <span class="status-badge connected" style="margin-left:4px;">Manual-enriched</span>
            {{/if}}
          </div>
          <div class="profile-card">
            <h5>Field Groups</h5>
            <div class="value">{{profile.fieldGroups.length}} groups</div>
          </div>
          {{#if profile.characterCreationSteps.length}}
          <div class="profile-card" style="grid-column: 1 / -1;">
            <h5>Character Creation Steps</h5>
            <ol style="margin:0; padding-left:1.2rem; font-size:0.8rem;">
              {{#each profile.characterCreationSteps}}
              <li>{{this}}</li>
              {{/each}}
            </ol>
          </div>
          {{/if}}
          {{#if profile.detectedConstraints.length}}
          <div class="profile-card" style="grid-column: 1 / -1;">
            <h5>Detected Constraints</h5>
            <ul>
              {{#each profile.detectedConstraints}}
              <li>{{this.description}}</li>
              {{/each}}
            </ul>
          </div>
          {{/if}}
        </div>
        {{else}}
        <p class="empty-state">No system profile yet. The AI will learn the system on first use.</p>
        {{/if}}

        <h4 class="section-header">Reference Character</h4>
        {{#if referenceCharacter}}
        <div class="profile-grid">
          <div class="profile-card" style="grid-column: 1 / -1;">
            <h5><i class="fas fa-user-check"></i> {{referenceCharacter.label}}</h5>
            <div class="value" style="font-size:0.8rem;">
              Type: <strong>{{referenceCharacter.actorType}}</strong>
              · Items: <strong>{{referenceCharacter.itemCount}}</strong>
              {{#if referenceCharacter.capturedAt}}
              · Captured: {{referenceCharacter.capturedAt}}
              {{/if}}
            </div>
            <p class="hint" style="margin-top:4px;">
              AI-generated characters of this type will replicate this character's exact structure.
            </p>
          </div>
        </div>
        <div class="btn-row" style="margin-top: 0.5rem;">
          <button type="button" class="btn btn-block btn-danger" data-action="clear-reference">
            <i class="fas fa-trash"></i> Clear Reference Character
          </button>
        </div>
        {{else}}
        <p class="empty-state">
          No reference character set. Right-click an actor in the sidebar → <em>"AI: Use as Reference Character"</em>
          to capture a manually-created character as the structural template.
        </p>
        {{/if}}

        <div class="profile-grid" style="margin-top:0.75rem;">
          <div class="profile-card" style="grid-column: 1 / -1;">
            <h5>Set from world actor</h5>
            <div class="form-group" style="margin-bottom:0.5rem;">
              <label for="ai-gm-reference-actor">Actor</label>
              <select id="ai-gm-reference-actor">
                <option value="">— Select an actor —</option>
                {{#each availableReferenceActors}}
                <option value="{{this.id}}">{{this.name}} ({{this.type}} · {{this.itemCount}} items)</option>
                {{/each}}
              </select>
            </div>
            <button type="button" class="btn btn-block" data-action="set-reference-character">
              <i class="fas fa-user-check"></i> Use selected actor as reference
            </button>
          </div>
        </div>

        <h4 class="section-header">System Skills</h4>
        <p class="hint">Skills are per-system adapters that fine-tune schema extraction and AI generation. Import a JSON skill or create one to customize behaviour for non-standard systems.</p>

        <div class="skill-list" id="gm-skill-list">
          {{#each skills}}
          <div class="skill-entry {{#unless this.enabled}}skill-disabled{{/unless}}" data-skill-id="{{this.id}}">
            <div class="skill-info">
              <strong>{{this.name}}</strong>
              <span class="skill-meta">{{this.systemId}}{{#if this.worldId}} / {{this.worldId}}{{/if}}</span>
              {{#if this.description}}
              <p class="hint" style="margin:2px 0 0;">{{this.description}}</p>
              {{/if}}
            </div>
            <div class="skill-actions">
              <button type="button" class="btn btn-sm" data-action="toggle-skill" data-skill-id="{{this.id}}" title="{{#if this.enabled}}Disable{{else}}Enable{{/if}}">
                <i class="fas {{#if this.enabled}}fa-toggle-on{{else}}fa-toggle-off{{/if}}"></i>
              </button>
              <button type="button" class="btn btn-sm" data-action="edit-skill" data-skill-id="{{this.id}}" title="Edit JSON">
                <i class="fas fa-edit"></i>
              </button>
              <button type="button" class="btn btn-sm btn-danger" data-action="delete-skill" data-skill-id="{{this.id}}" title="Remove">
                <i class="fas fa-trash"></i>
              </button>
            </div>
          </div>
          {{/each}}
          {{#unless skills.length}}
          <p class="empty-state">No skills loaded. Import a JSON skill file or create one.</p>
          {{/unless}}
        </div>

        <div class="btn-row" style="margin-top: 0.5rem;">
          <button type="button" class="btn" data-action="import-skill">
            <i class="fas fa-file-import"></i> Import Skill
          </button>
          <button type="button" class="btn" data-action="create-skill">
            <i class="fas fa-plus"></i> New Skill
          </button>
          <button type="button" class="btn" data-action="export-skills">
            <i class="fas fa-file-export"></i> Export All
          </button>
        </div>

        <h4 class="section-header">Connection</h4>
        <div class="profile-grid">
          <div class="profile-card">
            <h5>WebSocket</h5>
            {{#if wsConnected}}
            <span class="status-badge connected">Connected</span>
            {{else}}
            <span class="status-badge disconnected">Disconnected</span>
            {{/if}}
          </div>
          <div class="profile-card">
            <h5>Server</h5>
            <div class="value" style="font-size:0.8rem;">{{serverUrl}}</div>
          </div>
        </div>

        <div class="btn-row" style="margin-top: 1rem;">
          <button type="button" class="btn btn-block" data-action="relearn-system">
            <i class="fas fa-sync-alt"></i> Re-learn System
          </button>
          <button type="button" class="btn btn-block" data-action="reconnect-ws">
            <i class="fas fa-plug"></i> Reconnect WS
          </button>
        </div>
      </div>

      {{!-- Features subtab --}}
      <div class="ai-gm-subtab-content" data-subtab-content="config-features">
        <h4 class="section-header"><i class="fas fa-server"></i> Backend Connection</h4>
        <div class="form-group">
          <label for="ai-gm-server-url">Backend Server URL</label>
          <input type="text" id="ai-gm-server-url" value="{{serverUrl}}" placeholder="http://localhost:8080" />
          <p class="hint">URL of the AI Game Master backend server.</p>
        </div>
        <div class="btn-row">
          <button type="button" class="btn btn-primary btn-block" data-action="save-server-url">
            <i class="fas fa-save"></i> Save URL
          </button>
        </div>

        <h4 class="section-header"><i class="fas fa-toggle-on"></i> Feature Toggles</h4>
        <div class="features-toggle-list">
          <label class="feature-toggle-item">
            <input type="checkbox" id="ai-gm-enable-transcription" {{#if enableTranscription}}checked{{/if}}>
            <span class="feature-toggle-label">
              <i class="fas fa-microphone"></i>
              <strong>Enable Voice Transcription</strong>
              <span class="hint">Allow microphone capture during adventure sessions.</span>
            </span>
          </label>
          <label class="feature-toggle-item">
            <input type="checkbox" id="ai-gm-enable-game-director" {{#if enableGameDirector}}checked{{/if}}>
            <span class="feature-toggle-label">
              <i class="fas fa-dragon"></i>
              <strong>Enable Game Director</strong>
              <span class="hint">Enable the AI Game Director for real-time adventure narration.</span>
            </span>
          </label>
        </div>
      </div>
    </div>

    {{!-- ═══ GAME DIRECTOR TAB ═══ --}}
    <div class="tab" data-tab="game-director" data-group="primary">
      {{#if enableGameDirector}}
      <h4 class="section-header">Adventure Director</h4>
      <p class="hint">Carrega una aventura, inicia una sessió i deixa que el director narri en temps real.</p>

      <div class="form-group">
        <label for="adventure-select">Aventura</label>
        <select id="adventure-select" {{#if adventureSessionActive}}disabled{{/if}}>
          <option value="">— Selecciona una aventura —</option>
          {{#each adventures}}
            <option value="{{this.id}}" {{#if this.selected}}selected{{/if}}>{{this.title}} ({{this.system}})</option>
          {{/each}}
        </select>
      </div>

      <div class="form-group" style="display:flex;gap:0.5rem;flex-wrap:wrap;">
        <button type="button" class="btn" data-action="upload-adventure" {{#if adventureSessionActive}}disabled{{/if}}>
          <i class="fas fa-upload"></i> Pujar PDF d'aventura
        </button>
        {{#unless adventureSessionActive}}
          <button type="button" class="btn btn-primary" data-action="start-adventure" {{#unless adventureSelected}}disabled{{/unless}}>
            <i class="fas fa-play"></i> Iniciar aventura
          </button>
        {{/unless}}
        {{#if adventureSessionActive}}
          <button type="button" class="btn" data-action="end-adventure">
            <i class="fas fa-stop"></i> Finalitzar
          </button>
        {{/if}}
      </div>

      {{#if adventureSelected}}
        {{#unless adventureSessionActive}}
        {{#if adventureSavedSessions.length}}
          <div class="adventure-history" style="margin-top:8px;">
            <h5 class="section-header">Sessions anteriors</h5>
            <div style="display:flex;flex-direction:column;gap:6px;">
              {{#each adventureSavedSessions}}
                <div style="border:1px solid var(--color-border-light-tertiary);border-radius:6px;padding:8px;background:var(--color-bg-option);">
                  <div style="display:flex;justify-content:space-between;gap:8px;align-items:flex-start;flex-wrap:wrap;">
                    <div style="min-width:0;flex:1;">
                      <strong>{{this.sessionName}}</strong>
                      {{#if this.currentSceneTitle}}
                        <div class="hint">Escena actual: {{this.currentSceneTitle}}</div>
                      {{/if}}
                      {{#if this.participantNamesText}}
                        <div class="hint">Jugadors: {{this.participantNamesText}}</div>
                      {{/if}}
                      {{#if this.sessionSummary}}
                        <div style="margin-top:4px;white-space:pre-wrap;">{{this.sessionSummary}}</div>
                      {{/if}}
                      <div class="hint" style="margin-top:4px;">
                        Tensió: {{this.tensionLevel}} / 10
                        {{#if this.updatedAtLabel}} · Actualitzada: {{this.updatedAtLabel}}{{/if}}
                      </div>
                    </div>
                    <button type="button" class="btn" data-action="resume-adventure" data-session-id="{{this.id}}">
                      <i class="fas fa-rotate-left"></i> Reprendre
                    </button>
                  </div>
                </div>
              {{/each}}
            </div>
          </div>
        {{/if}}
        {{/unless}}
      {{/if}}

      {{#if adventureSessionActive}}
        <div class="adventure-session" style="border:1px solid var(--color-border-light-tertiary);padding:8px;border-radius:6px;margin-top:8px;">
          {{#if adventureSessionName}}
            <h4 class="section-header">{{adventureSessionName}}</h4>
          {{/if}}
          {{#if adventureSessionParticipants.length}}
            <div class="hint" style="margin-bottom:6px;">Jugadors: {{#each adventureSessionParticipants}}{{this}}{{#unless @last}}, {{/unless}}{{/each}}</div>
          {{/if}}
          {{#if adventureSessionSummary}}
            <div style="margin-bottom:8px;padding:6px 8px;background:var(--color-bg-option);border-radius:4px;white-space:pre-wrap;">{{adventureSessionSummary}}</div>
          {{/if}}
          {{#if adventureScene}}
            <h4 class="section-header">{{adventureScene.title}}</h4>
            <div class="read-aloud" style="font-style:italic;white-space:pre-wrap;border-left:3px solid var(--color-text-hyperlink);padding:6px 10px;margin-bottom:8px;">{{adventureScene.readAloudText}}</div>
          {{/if}}

          <div class="adventure-status" style="display:grid;grid-template-columns:1fr 1fr;gap:8px;margin-bottom:8px;">
            <div>
              <strong>Pistes descobertes</strong>
              <ul style="margin:4px 0 0 1rem;padding:0;">
                {{#each discoveredClues}}<li>{{this}}</li>{{else}}<li class="hint">cap encara</li>{{/each}}
              </ul>
            </div>
            <div>
              <strong>NPCs trobats</strong>
              <ul style="margin:4px 0 0 1rem;padding:0;">
                {{#each metNpcs}}<li>{{this}}</li>{{else}}<li class="hint">cap encara</li>{{/each}}
              </ul>
            </div>
          </div>

          {{#if adventureNpcs.length}}
          <div style="margin-bottom:8px;">
            <strong><i class="fas fa-users"></i> NPCs de l'aventura</strong>
            <div style="display:flex;flex-direction:column;gap:3px;margin-top:4px;">
              {{#each adventureNpcs}}
              <div style="display:flex;align-items:center;gap:6px;padding:4px 6px;border-radius:4px;background:var(--color-bg-option);">
                <i class="fas fa-user" style="opacity:0.6;"></i>
                <span style="flex:1;font-size:0.9em;">
                  <strong>{{this.name}}</strong>
                  {{#if this.currentDisposition}}<span class="hint">({{this.currentDisposition}})</span>{{/if}}
                </span>
                <button type="button" class="btn btn-sm" data-action="create-adventure-npc" data-npc-id="{{this.id}}" title="Crear actor a Foundry">
                  <i class="fas fa-user-plus"></i>
                </button>
              </div>
              {{/each}}
            </div>
          </div>
          {{/if}}

          <div class="tension" style="margin-bottom:8px;">
            <label><strong>Tensió</strong> {{tensionLevel}} / {{tensionMax}}</label>
            <div style="background:var(--color-bg-option);height:10px;border-radius:5px;overflow:hidden;border:1px solid var(--color-border-dark-tertiary);">
              <div style="height:100%;width:{{tensionPct}}%;background:linear-gradient(90deg,#4caf50,#ff9800,#f44336);"></div>
            </div>
          </div>

          {{#if speakingNpc}}
            <div class="npc-speaking" style="background:var(--color-bg-option);padding:6px 8px;border-radius:4px;margin-bottom:8px;">
              <i class="fas fa-volume-up"></i> <strong>{{speakingNpc.npcName}}</strong> està parlant…
            </div>
          {{/if}}

          <div class="form-group" style="display:flex;gap:0.5rem;align-items:center;flex-wrap:wrap;">
            {{#if enableTranscription}}
            <button type="button" class="btn {{#if isRecording}}btn-danger{{/if}}" data-action="toggle-mic" style="flex-shrink:0;">
              <i class="fas fa-microphone{{#if isRecording}}-slash{{/if}}"></i>
            </button>
            {{/if}}
            <input type="text" id="adventure-text-input" placeholder="Escriu la teva acció…" style="flex:1;min-width:120px;" {{#if isProcessing}}disabled{{/if}} />
            <button type="button" class="btn" data-action="send-adventure-text" style="flex-shrink:0;" {{#if isProcessing}}disabled{{/if}}>
              <i class="fas fa-paper-plane"></i>
            </button>
            {{#if isProcessing}}<span class="hint" style="width:100%;"><i class="fas fa-spinner fa-spin"></i> Processant…</span>{{/if}}
          </div>

          <h5 class="section-header" style="margin-top:8px;">Registre</h5>
          <div class="adventure-log" style="max-height:240px;overflow-y:auto;border:1px solid var(--color-border-light-tertiary);padding:6px;border-radius:4px;font-size:0.9em;">
            {{#each adventureLog}}<div style="margin-bottom:4px;">{{this}}</div>{{else}}<div class="hint">Encara no hi ha res…</div>{{/each}}
          </div>
        </div>
      {{/if}}
      {{else}}
      <h4 class="section-header">Game Director Disabled</h4>
      <p class="hint">Enable the Game Director feature to use adventure narration tools.</p>
      <label class="feature-toggle-item">
        <input type="checkbox" id="ai-gm-enable-game-director-quick">
        <span class="feature-toggle-label">
          <i class="fas fa-dragon"></i>
          <strong>Enable Game Director</strong>
          <span class="hint">Turn this on to access adventure sessions.</span>
        </span>
      </label>
      {{/if}}
    </div>

    {{!-- ═══ TRANSCRIPTION TAB ═══ --}}
    <div class="tab" data-tab="transcription" data-group="primary">
      <h4 class="section-header">Transcription</h4>
      <p class="hint">Enable or disable voice transcription for live audio capture during game director sessions.</p>

      <label class="feature-toggle-item">
        <input type="checkbox" id="ai-gm-enable-transcription-quick" {{#if enableTranscription}}checked{{/if}}>
        <span class="feature-toggle-label">
          <i class="fas fa-microphone"></i>
          <strong>Enable Voice Transcription</strong>
          <span class="hint">When enabled, microphone controls appear in Game Director sessions.</span>
        </span>
      </label>

      <div class="profile-grid" style="margin-top:0.75rem;">
        <div class="profile-card">
          <h5>Current Status</h5>
          {{#if enableTranscription}}
          <span class="status-badge connected">Enabled</span>
          {{else}}
          <span class="status-badge disconnected">Disabled</span>
          {{/if}}
        </div>
        <div class="profile-card">
          <h5>Server</h5>
          <div class="value" style="font-size:0.8rem;">{{serverUrl}}</div>
        </div>
      </div>
    </div>

  </section>
</div>
